# 의존성 패키지 (npm install로 언제든 다시 받을 수 있어서 저장 안 함)
node_modules/

# 비밀 정보 (API 키 등 — 절대 저장소에 올리면 안 됨)
.env
.env.*

# 맥OS가 자동 생성하는 시스템 파일
.DS_Store

# 빌드 결과물 (소스에서 다시 만들 수 있음)
dist/
build/

# 네이티브 앱 빌드 캐시
ios/App/Pods/
android/.gradle/
android/app/build/

# 개인 로컬 설정
.claude/settings.local.json
ios/App/Pods/
ios/App/build/
ios/DerivedData/
